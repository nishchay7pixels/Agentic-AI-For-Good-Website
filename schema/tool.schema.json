{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Tool",
  "description": "Schema for a tool submission to Agentic AI For Good",
  "type": "object",
  "required": ["name", "description", "problem_solved", "use_cases"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Tool name"
    },
    "description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 500,
      "description": "1-3 sentences: what this tool does"
    },
    "problem_solved": {
      "type": "string",
      "minLength": 50,
      "description": "Why this tool is unique and what specific problem it solves. Be concrete."
    },
    "use_cases": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 10
      },
      "description": "At least 3 concrete use cases. More is better — embeddings pick them all up."
    },
    "github_url": {
      "type": "string",
      "pattern": "^https://github\\.com/.+",
      "description": "GitHub repository URL"
    },
    "website_url": {
      "type": "string",
      "pattern": "^https?://.+",
      "description": "Official website URL"
    },
    "docs_url": {
      "type": "string",
      "pattern": "^https?://.+",
      "description": "Documentation URL"
    },
    "install_command": {
      "type": "string",
      "description": "e.g. 'pip install langchain' or 'npm install @langchain/core'"
    },
    "category": {
      "type": "string",
      "enum": ["LLM", "Vector DB", "RAG", "Agents", "Fine-tuning", "Monitoring", "Data", "Dev Tools", "Other"],
      "description": "Primary category"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Relevant tags for filtering"
    },
    "pricing": {
      "type": "string",
      "enum": ["free", "freemium", "paid"],
      "default": "free"
    },
    "is_open_source": {
      "type": "boolean",
      "default": false
    },
    "license": {
      "type": "string",
      "description": "e.g. MIT, Apache-2.0, BSL-1.1"
    },
    "tagline": {
      "type": "string",
      "maxLength": 100,
      "description": "One-liner shown on cards. If omitted, first sentence of description is used."
    }
  },
  "anyOf": [
    { "required": ["github_url"] },
    { "required": ["website_url"] }
  ]
}
